###############################################################################
# Athena
# .gitignore
###############################################################################

###############################################################################
# Python
###############################################################################

__pycache__/
*.py[cod]
*$py.class
*.so

###############################################################################
# Virtual Environments
###############################################################################

.venv/
venv/
env/
ENV/

###############################################################################
# Build
###############################################################################

build/
dist/
*.egg-info/
.eggs/

###############################################################################
# Testing
###############################################################################

.pytest_cache/
.coverage
.coverage.*
htmlcov/

###############################################################################
# Type Checking
###############################################################################

.mypy_cache/
.pyre/
.pytype/

###############################################################################
# Linters / Formatting
###############################################################################

.ruff_cache/
.cache/

###############################################################################
# Jupyter
###############################################################################

.ipynb_checkpoints/

###############################################################################
# IDE
###############################################################################

.vscode/
.idea/

###############################################################################
# macOS
###############################################################################

.DS_Store

###############################################################################
# Logs
###############################################################################

*.log
logs/
outputs/logs/

###############################################################################
# Runtime Outputs
###############################################################################

outputs/reports/
outputs/submissions/
outputs/benchmarks/

###############################################################################
# Runtime Data
###############################################################################

data/cache/
data/processed/
data/embeddings/
data/indices/


###############################################################################
# Environment Files
###############################################################################

.env
.env.*

###############################################################################
# Temporary Files
###############################################################################

*.tmp
*.temp
*.bak
*.swp
*.swo

###############################################################################
# Package Manager
###############################################################################

pip-wheel-metadata/

###############################################################################
# OS Files
###############################################################################

Thumbs.db
Desktop.ini

###############################################################################
# Keep Empty Project Structure
###############################################################################

!data/raw/.gitkeep
!outputs/.gitkeep
!tests/.gitkeepdatasets/redrob/candidates.jsonl
datasets/redrob/candidates.jsonl
.venv/
datasets/redrob/
